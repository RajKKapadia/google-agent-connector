# Public HTTPS URL used for widget embeds, webhooks, and browser links
NEXT_PUBLIC_APP_URL=https://your-domain.example.com

# App services in docker-compose.prod.yml resolve Postgres and Redis by service name
DATABASE_URL=postgresql://cesuser:change-me@postgres:5432/cesconnector
REDIS_URL=redis://redis:6379

# Internal Postgres container credentials
POSTGRES_USER=cesuser
POSTGRES_PASSWORD=change-me
POSTGRES_DB=cesconnector

# 64 hex chars (32 bytes). Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Session signing secret for local admin auth. Generate with: openssl rand -hex 32
AUTH_SESSION_SECRET=

# Optional worker tuning
WORKER_CONCURRENCY=5
WORKER_SESSION_LOCK_TTL_MS=120000
WORKER_SESSION_LOCK_WAIT_MS=30000
