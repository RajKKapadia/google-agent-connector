# Public base URL used for webhook/widget URLs and browser links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database connection string
DATABASE_URL=postgresql://cesuser:cespass@localhost:5432/cesconnector

# Redis connection string for BullMQ and realtime events
REDIS_URL=redis://localhost:6379

# 64 hex chars (32 bytes). Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Session signing secret for local admin auth. Generate with: openssl rand -hex 32
AUTH_SESSION_SECRET=
